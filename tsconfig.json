{
  // https://nuxt.com/docs/guide/concepts/typescript
  "files": [],
  "references": [
    {
      "path": "./.nuxt/tsconfig.app.json"
    },
    {
      "path": "./.nuxt/tsconfig.server.json"
    },
    {
      "path": "./.nuxt/tsconfig.shared.json"
    },
    {
      "path": "./.nuxt/tsconfig.node.json"
    }
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    ".output",
    "dist",
    "coverage"
  ],
  "compilerOptions": {
    "types": ["node"],
    "paths": {
      "@core/*": ["./layers/10-core/*"],
      "@infra/*": ["./layers/20-infra/*"],
      "@shared/*": ["./layers/25-shared/*"],
      "@user/*": ["./layers/30-user/*"],
      "@auth/*": ["./layers/40-auth/*"],
      "@collection/*": ["./layers/60-collection/*"]
    }
  }
}
